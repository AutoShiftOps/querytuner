# ─────────────────────────────────────────────
# QueryTuner — Backend Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── HuggingFace (default AI provider, free tier) ──
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct
HF_ROUTER_BASE_URL=https://router.huggingface.co

# ── OpenAI (optional, uncomment to enable) ──
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# ── LLM defaults ──
DEFAULT_LLM_PROVIDER=huggingface
AI_MAX_TOKENS=800

# ── Query limits ──
MAX_QUERY_CHARS=20000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
